# ==========================================
# FITBIT CONFIGURATION
# ==========================================
FITBIT_CLIENT_ID=your_fitbit_client_id_here
FITBIT_CLIENT_SECRET=your_fitbit_client_secret_here
FITBIT_REDIRECT_URI=http://localhost:3000/auth/fitbit/callback
FITBIT_API_BASE_URL=https://api.fitbit.com/1

# ==========================================
# CLAUDE AI (ANTHROPIC) CONFIGURATION
# ==========================================
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-opus-20240229
CLAUDE_MAX_TOKENS=1024
CLAUDE_TEMPERATURE=0.7

# ==========================================
# IFTTT CONFIGURATION
# ==========================================
IFTTT_WEBHOOK_KEY=your_ifttt_webhook_key_here
IFTTT_WEBHOOK_URL=https://maker.ifttt.com/trigger

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# ==========================================
# JWT & SECURITY
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=7d

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/fitbit_trainer
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=fitbit_trainer

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ==========================================
# SCHEDULED TASKS
# ==========================================
SCHEDULE_TIME=06:00
SCHEDULE_TIMEZONE=America/New_York

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_DAILY_INSIGHTS=true
ENABLE_IFTTT_WEBHOOKS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false
